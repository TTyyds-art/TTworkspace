    <property name="styleSheet">
     <string notr="true">QGroupBox {
    background-color: #f8f9fa;          /* 浅灰背景 */
    border: 2px solid #d0d7de;           /* 外边框 */
    border-radius: 18px;                  /* 圆角 */
    margin-top: 12px;                      /* 为标题留出空间（标题本身会占据位置） */
    padding-top: 8px;                      /* 内边距，避免内容紧贴边框 */
    box-shadow: 0 4px 8px rgba(0, 0, 0, 0.15);  /* 外阴影，使整体凸起 */
}
</string>
