                 <property name="styleSheet">
                  <string notr="true">/* 所有 QRadioButton 的基础样式 */
QRadioButton {
    background-color: #f0f0f0;        /* 未选中时的背景色 */
    color: #333333;                    /* 未选中时的文字颜色 */
    border: 1px solid #cccccc;          /* 边框 */
    border-radius: 15px;                /* 圆角，可根据高度调整 */
    padding: 5px 15px;                  /* 内边距，增大点击区域 */
    spacing: 5px;                        
}


/* 选中时的样式 */
QRadioButton:checked {
    background-color: #4CAF50;          /* 绿色背景 */
    color: white;                        /* 白色文字 */
    border: 1px solid #27ae60;           
}

/* 悬停效果 */
QRadioButton:hover {
    background-color: #e0e0e0;
}
QRadioButton:checked:hover {
    background-color: #66BB6A;
}

QRadioButton::indicator {
    width: 0px;                       /* 隐藏默认的指示器（小圆圈） */
    height: 0px;
}</string>
                 </property>
                 <property name="text">
